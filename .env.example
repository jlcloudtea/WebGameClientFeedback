# Database — PostgreSQL connection string
# For local development with Docker:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ict_support_pro

# For Vercel Postgres (Neon), use the connection string from your Vercel dashboard:
# DATABASE_URL=postgresql://username:password@ep-xxx.region.aws.neon.tech/ict_support_pro?sslmode=require

# Cron secret — protects the /api/admin/cleanup endpoint
# Set this to a random string and use it in your cron-job.org URL
CRON_SECRET=your-random-secret-here
